# ==========================================
# Trading Intelligence Platform Config Env
# ==========================================

# 1. Database Configuration
# Set USE_SQLITE=False if you want to use PostgreSQL
USE_SQLITE=True
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_db
SQLITE_URL=sqlite:///./trading_platform_dev.db

# 2. MetaTrader 5 Configuration (Windows only)
# Required if you want to connect to a live MT5 terminal
MT5_LOGIN=0
MT5_PASSWORD=your_password_here
MT5_SERVER=your_broker_server_here
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# 3. AI / LLM Configuration
# Optional: Get your key from Google AI Studio to enable market analysis and chat advisor
GEMINI_API_KEY=your_gemini_api_key_here
